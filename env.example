# ─────────────────────────────────────────────────
# Voice2WA – Environment Variables
# Copy this file to .env.local for local development
# Add these as Environment Variables in the Vercel dashboard
# ─────────────────────────────────────────────────

# ── AI (required) ──────────────────────────────────
# Primary AI provider (fast + free tier available)
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Fallback AI provider (used if Groq fails)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── Google AdSense (optional — enables ads) ────────
# Your AdSense publisher ID, e.g. ca-pub-1234567890123456
# Ads only render when this is set; leave empty to disable ads.
# NEXT_PUBLIC_ prefix is required so the client can read it.
NEXT_PUBLIC_ADSENSE_CLIENT=

# ── Razorpay payments (optional — enables Pro upgrade) ─
# Get keys at: https://dashboard.razorpay.com/app/keys
# Use LIVE keys to accept real money. Server-side only (never exposed):
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional: pin the public site URL used for Razorpay's return/callback.
# If unset, the request origin is used (works on Vercel automatically).
# APP_URL=https://your-app.vercel.app
